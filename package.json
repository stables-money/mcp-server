{
  "name": "stables-mcp-server",
  "version": "1.3.0",
  "description": "MCP server for Stables fiat-to-crypto API - enables AI agents to manage customers, quotes, and transfers",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "stables-mcp-server": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "stables",
    "crypto",
    "fiat",
    "stablecoin",
    "payments",
    "ai-agents",
    "model-context-protocol",
    "claude",
    "chatgpt"
  ],
  "author": "Stables (https://stables.money)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stables-money/mcp-server.git"
  },
  "homepage": "https://docs.stables.money",
  "bugs": {
    "url": "https://github.com/stables-money/mcp-server/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
